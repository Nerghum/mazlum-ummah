NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://root:rootpassword@localhost:27017/newspaper_cms?authSource=admin
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
PASSWORD_RESET_EXPIRES_MINUTES=15
UPLOAD_DIR=uploads
MAX_FILE_MB=25
